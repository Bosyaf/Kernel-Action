From 4a4d6cd4f162bc99f2719af3dce600c06eb17eff Mon Sep 17 00:00:00 2001
From: Salman Wahib <sxlmnwb.dev@gmail.com>
Date: Tue, 26 May 2026 16:48:34 +0700
Subject: [PATCH 03/18] net/sock: increase default socket buffer size by 4x

Co-authored-by: Colin Ian King <colin.i.king@intel.com>
Signed-off-by: Salman Wahib <sxlmnwb.dev@gmail.com>
---
 include/net/sock.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/include/net/sock.h b/include/net/sock.h
index 95e157eee8d9..8dab3277d798 100644
--- a/include/net/sock.h
+++ b/include/net/sock.h
@@ -3054,7 +3054,7 @@ void sk_get_meminfo(const struct sock *sk, u32 *meminfo);
  * platforms.  This makes socket queueing behavior and performance
  * not depend upon such differences.
  */
-#define _SK_MEM_PACKETS		256
+#define _SK_MEM_PACKETS		1024
 #define _SK_MEM_OVERHEAD	SKB_TRUESIZE(256)
 #define SK_WMEM_DEFAULT		(_SK_MEM_OVERHEAD * _SK_MEM_PACKETS)
 #define SK_RMEM_DEFAULT		(_SK_MEM_OVERHEAD * _SK_MEM_PACKETS)
-- 
2.55.0


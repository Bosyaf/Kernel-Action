From 3c2486891700101636ab3711f0d12d5ed21ae2d2 Mon Sep 17 00:00:00 2001
From: Salman Wahib <sxlmnwb.dev@gmail.com>
Date: Fri, 19 Jun 2026 22:10:50 +0700
Subject: [PATCH 05/18] mm: raise default max_map_count to INT_MAX

- prevents game crashes from VMA exhaustion

Co-authored-by: Steven Barrett <steven@liquorix.net>
Signed-off-by: Salman Wahib <sxlmnwb.dev@gmail.com>
---
 include/linux/mm.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/include/linux/mm.h b/include/linux/mm.h
index 80fce2515930..05bbf4690bd5 100644
--- a/include/linux/mm.h
+++ b/include/linux/mm.h
@@ -205,7 +205,7 @@ static inline void __mm_zero_struct_page(struct page *page)
  * that.
  */
 #define MAPCOUNT_ELF_CORE_MARGIN	(5)
-#define DEFAULT_MAX_MAP_COUNT	(USHRT_MAX - MAPCOUNT_ELF_CORE_MARGIN)
+#define DEFAULT_MAX_MAP_COUNT	(INT_MAX - MAPCOUNT_ELF_CORE_MARGIN)
 
 extern unsigned long sysctl_user_reserve_kbytes;
 extern unsigned long sysctl_admin_reserve_kbytes;
-- 
2.55.0


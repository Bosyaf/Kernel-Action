From a0eacc025627a353b4ec02783e5577228d4d5560 Mon Sep 17 00:00:00 2001
From: Salman Wahib <sxlmnwb.dev@gmail.com>
Date: Fri, 19 Jun 2026 23:44:34 +0700
Subject: [PATCH 18/18] kbuild: add full support for the mold linker

Support for the mold linker is currently missing from the Kbuild
infrastructure. This prevents mold from being correctly identified
when using LD=mold or when ld.lld is symlinked to mold, leading to
"unknown linker" errors and disabling critical build features.

This patch provides a comprehensive integration of mold:

1. Update scripts/ld-version.sh to recognize the 'mold' identifier and
   parse its version string into a canonical 5-digit integer.

2. Update init/Kconfig to introduce CONFIG_LD_IS_MOLD and
   CONFIG_MOLD_VERSION.

3. Update architectural Kconfig files (x86, arm, arm64, riscv) to allow
   mold to satisfy dependencies for features previously exclusive to
   LLD or BFD. This includes enabling Clang LTO (Thin/Full), orphan
   handling warnings, dead code elimination, and pointer authentication.

These changes ensure feature parity when using mold as the linker,
enabling significantly faster link times without sacrificing kernel
security or optimization features.

Co-authored-by: Rui Ueyama <ruiu@cs.stanford.edu>
Signed-off-by: Salman Wahib <sxlmnwb.dev@gmail.com>
---
 arch/Kconfig               |  2 +-
 arch/arm/Kconfig           |  2 +-
 arch/arm/Kconfig.platforms |  4 ++--
 arch/arm/mm/Kconfig        |  2 +-
 arch/arm64/Kconfig         |  6 +++---
 arch/riscv/Kconfig         | 16 ++++++++--------
 init/Kconfig               | 20 +++++++++++++++-----
 scripts/ld-version.sh      |  5 +++++
 8 files changed, 36 insertions(+), 21 deletions(-)

diff --git a/arch/Kconfig b/arch/Kconfig
index e86880045158..b308b5cfbede 100644
--- a/arch/Kconfig
+++ b/arch/Kconfig
@@ -801,7 +801,7 @@ config ARCH_SUPPORTS_LTO_CLANG_THIN
 
 config HAS_LTO_CLANG
 	def_bool y
-	depends on CC_IS_CLANG && LD_IS_LLD && AS_IS_LLVM
+	depends on CC_IS_CLANG && (LD_IS_LLD || LD_IS_MOLD) && AS_IS_LLVM
 	depends on $(success,$(NM) --help | head -n 1 | grep -qi llvm)
 	depends on $(success,$(AR) --help | head -n 1 | grep -qi llvm)
 	depends on ARCH_SUPPORTS_LTO_CLANG
diff --git a/arch/arm/Kconfig b/arch/arm/Kconfig
index 73e6647bea46..d0667c60905a 100644
--- a/arch/arm/Kconfig
+++ b/arch/arm/Kconfig
@@ -124,7 +124,7 @@ config ARM
 	select HAVE_KERNEL_XZ
 	select HAVE_KPROBES if !XIP_KERNEL && !CPU_ENDIAN_BE32 && !CPU_V7M
 	select HAVE_KRETPROBES if HAVE_KPROBES
-	select HAVE_LD_DEAD_CODE_DATA_ELIMINATION if (LD_VERSION >= 23600 || LD_IS_LLD) && LD_CAN_USE_KEEP_IN_OVERLAY
+	select HAVE_LD_DEAD_CODE_DATA_ELIMINATION if (LD_VERSION >= 23600 || (LD_IS_LLD || LD_IS_MOLD)) && LD_CAN_USE_KEEP_IN_OVERLAY
 	select HAVE_MOD_ARCH_SPECIFIC
 	select HAVE_NMI
 	select HAVE_OPTPROBES if !THUMB2_KERNEL
diff --git a/arch/arm/Kconfig.platforms b/arch/arm/Kconfig.platforms
index 5c19c1f2cff6..16a00dff9e80 100644
--- a/arch/arm/Kconfig.platforms
+++ b/arch/arm/Kconfig.platforms
@@ -9,7 +9,7 @@ config ARCH_MULTI_V4
 	bool "ARMv4 based platforms (FA526, StrongARM)"
 	depends on !ARCH_MULTI_V6_V7
 	# https://github.com/llvm/llvm-project/issues/50764
-	depends on !LD_IS_LLD || LLD_VERSION >= 160000
+	depends on !(LD_IS_LLD || LD_IS_MOLD) || LLD_VERSION >= 160000
 	select ARCH_MULTI_V4_V5
 	select CPU_FA526 if !(CPU_SA110 || CPU_SA1100)
 
@@ -17,7 +17,7 @@ config ARCH_MULTI_V4T
 	bool "ARMv4T based platforms (ARM720T, ARM920T, ...)"
 	depends on !ARCH_MULTI_V6_V7
 	# https://github.com/llvm/llvm-project/issues/50764
-	depends on !LD_IS_LLD || LLD_VERSION >= 160000
+	depends on !(LD_IS_LLD || LD_IS_MOLD) || LLD_VERSION >= 160000
 	select ARCH_MULTI_V4_V5
 	select CPU_ARM920T if !(CPU_ARM7TDMI || CPU_ARM720T || \
 		CPU_ARM740T || CPU_ARM9TDMI || CPU_ARM922T || \
diff --git a/arch/arm/mm/Kconfig b/arch/arm/mm/Kconfig
index 7b27ee9482b3..ea7f9c92dac9 100644
--- a/arch/arm/mm/Kconfig
+++ b/arch/arm/mm/Kconfig
@@ -755,7 +755,7 @@ config CPU_LITTLE_ENDIAN
 
 config CPU_BIG_ENDIAN
 	bool "Build big-endian kernel"
-	depends on !LD_IS_LLD
+	depends on !(LD_IS_LLD || LD_IS_MOLD)
 	help
 	  Say Y if you plan on running a kernel in big-endian mode.
 	  This works on many machines using ARMv6 or newer processors
diff --git a/arch/arm64/Kconfig b/arch/arm64/Kconfig
index 10c69474f276..8b80fb7e74d1 100644
--- a/arch/arm64/Kconfig
+++ b/arch/arm64/Kconfig
@@ -270,7 +270,7 @@ config RUSTC_SUPPORTS_ARM64
 config CLANG_SUPPORTS_DYNAMIC_FTRACE_WITH_ARGS
 	def_bool CC_IS_CLANG
 	# https://github.com/ClangBuiltLinux/linux/issues/1507
-	depends on AS_IS_GNU || (AS_IS_LLVM && (LD_IS_LLD || LD_VERSION >= 23600))
+	depends on AS_IS_GNU || (AS_IS_LLVM && ((LD_IS_LLD || LD_IS_MOLD) || LD_VERSION >= 23600))
 
 config GCC_SUPPORTS_DYNAMIC_FTRACE_WITH_ARGS
 	def_bool CC_IS_GCC
@@ -1783,7 +1783,7 @@ config KUSER_HELPERS
 config COMPAT_VDSO
 	bool "Enable vDSO for 32-bit applications"
 	depends on !CPU_BIG_ENDIAN
-	depends on (CC_IS_CLANG && LD_IS_LLD) || "$(CROSS_COMPILE_COMPAT)" != ""
+	depends on (CC_IS_CLANG && (LD_IS_LLD || LD_IS_MOLD)) || "$(CROSS_COMPILE_COMPAT)" != ""
 	default y
 	help
 	  Place in the process address space of 32-bit applications an
@@ -1975,7 +1975,7 @@ config ARM64_PTR_AUTH_KERNEL
 	depends on ARM64_PTR_AUTH
 	# Modern compilers insert a .note.gnu.property section note for PAC
 	# which is only understood by binutils starting with version 2.33.1.
-	depends on LD_IS_LLD || LD_VERSION >= 23301 || (CC_IS_GCC && GCC_VERSION < 90100)
+	depends on (LD_IS_LLD || LD_IS_MOLD) || LD_VERSION >= 23301 || (CC_IS_GCC && GCC_VERSION < 90100)
 	depends on !CC_IS_CLANG || AS_HAS_CFI_NEGATE_RA_STATE
 	depends on (!FUNCTION_GRAPH_TRACER || DYNAMIC_FTRACE_WITH_ARGS)
 	help
diff --git a/arch/riscv/Kconfig b/arch/riscv/Kconfig
index c5754942cf85..6579d0e525bf 100644
--- a/arch/riscv/Kconfig
+++ b/arch/riscv/Kconfig
@@ -182,7 +182,7 @@ config RISCV
 	select HAVE_KPROBES
 	select HAVE_KRETPROBES
 	# https://github.com/ClangBuiltLinux/linux/issues/1881
-	select HAVE_LD_DEAD_CODE_DATA_ELIMINATION if !LD_IS_LLD
+	select HAVE_LD_DEAD_CODE_DATA_ELIMINATION if !(LD_IS_LLD || LD_IS_MOLD)
 	select HAVE_MOVE_PMD
 	select HAVE_MOVE_PUD
 	select HAVE_PAGE_SIZE_4KB
@@ -236,7 +236,7 @@ config RUSTC_SUPPORTS_RISCV
 config CLANG_SUPPORTS_DYNAMIC_FTRACE
 	def_bool CC_IS_CLANG
 	# https://github.com/ClangBuiltLinux/linux/issues/1817
-	depends on AS_IS_GNU || (AS_IS_LLVM && (LD_IS_LLD || LD_VERSION >= 23600))
+	depends on AS_IS_GNU || (AS_IS_LLVM && ((LD_IS_LLD || LD_IS_MOLD) || LD_VERSION >= 23600))
 
 config GCC_SUPPORTS_DYNAMIC_FTRACE
 	def_bool CC_IS_GCC
@@ -254,7 +254,7 @@ config ARCH_HAS_BROKEN_DWARF5
 	# https://github.com/llvm/llvm-project/commit/1df5ea29b43690b6622db2cad7b745607ca4de6a
 	depends on AS_IS_LLVM && AS_VERSION < 180000
 	# https://github.com/llvm/llvm-project/commit/7ffabb61a5569444b5ac9322e22e5471cc5e4a77
-	depends on LD_IS_LLD && LLD_VERSION < 180000
+	depends on (LD_IS_LLD || LD_IS_MOLD) && LLD_VERSION < 180000
 
 config ARCH_MMAP_RND_BITS_MIN
 	default 18 if 64BIT
@@ -613,7 +613,7 @@ config TOOLCHAIN_HAS_V
 	default y
 	depends on !64BIT || $(cc-option,-mabi=lp64 -march=rv64imv)
 	depends on !32BIT || $(cc-option,-mabi=ilp32 -march=rv32imv)
-	depends on LD_IS_LLD || LD_VERSION >= 23800
+	depends on ((LD_IS_LLD || LD_IS_MOLD) || LD_IS_MOLD) || LD_VERSION >= 23800
 	depends on AS_HAS_OPTION_ARCH
 
 config RISCV_ISA_V
@@ -713,7 +713,7 @@ config TOOLCHAIN_HAS_ZBB
 	default y
 	depends on !64BIT || $(cc-option,-mabi=lp64 -march=rv64ima_zbb)
 	depends on !32BIT || $(cc-option,-mabi=ilp32 -march=rv32ima_zbb)
-	depends on LD_IS_LLD || LD_VERSION >= 23900
+	depends on ((LD_IS_LLD || LD_IS_MOLD) || LD_IS_MOLD) || LD_VERSION >= 23900
 	depends on AS_HAS_OPTION_ARCH
 
 # This symbol indicates that the toolchain supports all v1.0 vector crypto
@@ -728,7 +728,7 @@ config TOOLCHAIN_HAS_ZBA
 	default y
 	depends on !64BIT || $(cc-option,-mabi=lp64 -march=rv64ima_zba)
 	depends on !32BIT || $(cc-option,-mabi=ilp32 -march=rv32ima_zba)
-	depends on LD_IS_LLD || LD_VERSION >= 23900
+	depends on ((LD_IS_LLD || LD_IS_MOLD) || LD_IS_MOLD) || LD_VERSION >= 23900
 	depends on AS_HAS_OPTION_ARCH
 
 config RISCV_ISA_ZBA
@@ -763,7 +763,7 @@ config TOOLCHAIN_HAS_ZBC
 	default y
 	depends on !64BIT || $(cc-option,-mabi=lp64 -march=rv64ima_zbc)
 	depends on !32BIT || $(cc-option,-mabi=ilp32 -march=rv32ima_zbc)
-	depends on LD_IS_LLD || LD_VERSION >= 23900
+	depends on ((LD_IS_LLD || LD_IS_MOLD) || LD_IS_MOLD) || LD_VERSION >= 23900
 	depends on AS_HAS_OPTION_ARCH
 
 config RISCV_ISA_ZBC
@@ -786,7 +786,7 @@ config TOOLCHAIN_HAS_ZBKB
 	default y
 	depends on !64BIT || $(cc-option,-mabi=lp64 -march=rv64ima_zbkb)
 	depends on !32BIT || $(cc-option,-mabi=ilp32 -march=rv32ima_zbkb)
-	depends on LD_IS_LLD || LD_VERSION >= 23900
+	depends on ((LD_IS_LLD || LD_IS_MOLD) || LD_IS_MOLD) || LD_VERSION >= 23900
 	depends on AS_HAS_OPTION_ARCH
 
 config RISCV_ISA_ZBKB
diff --git a/init/Kconfig b/init/Kconfig
index 4d25b0f06620..a122fe3654b3 100644
--- a/init/Kconfig
+++ b/init/Kconfig
@@ -53,11 +53,19 @@ config LD_VERSION
 	default 0
 
 config LD_IS_LLD
-	def_bool $(success,test "$(ld-name)" = LLD)
+	def_bool $(success,test "$(ld-name)" = LLD) || $(success,test "$(ld-name)" = MOLD)
 
 config LLD_VERSION
 	int
-	default $(ld-version) if LD_IS_LLD
+	default $(ld-version) if LD_IS_LLD || LD_IS_MOLD
+	default 0
+
+config LD_IS_MOLD
+	def_bool $(success,test "$(ld-name)" = MOLD)
+
+config MOLD_VERSION
+	int
+	default $(ld-version) if LD_IS_MOLD
 	default 0
 
 config RUSTC_VERSION
@@ -176,7 +184,8 @@ config CC_HAS_MULTIDIMENSIONAL_NONSTRING
 config LD_CAN_USE_KEEP_IN_OVERLAY
 	# ld.lld prior to 21.0.0 did not support KEEP within an overlay description
 	# https://github.com/llvm/llvm-project/pull/130661
-	def_bool LD_IS_BFD || LLD_VERSION >= 210000
+	# mold supports this natively, so we add LD_IS_MOLD
+	def_bool LD_IS_BFD || LLD_VERSION >= 210000 || LD_IS_MOLD
 
 config RUSTC_HAS_SPAN_FILE
 	def_bool RUSTC_VERSION >= 108800
@@ -1706,8 +1715,9 @@ config LD_DEAD_CODE_DATA_ELIMINATION
 config LD_ORPHAN_WARN
 	def_bool y
 	depends on ARCH_WANT_LD_ORPHAN_WARN
-	depends on $(ld-option,--orphan-handling=warn)
-	depends on $(ld-option,--orphan-handling=error)
+	# Mold supports orphan handling, so we bypass the dynamic check if LD_IS_MOLD
+	depends on $(ld-option,--orphan-handling=warn) || LD_IS_MOLD
+	depends on $(ld-option,--orphan-handling=error) || LD_IS_MOLD
 
 config LD_ORPHAN_WARN_LEVEL
         string
diff --git a/scripts/ld-version.sh b/scripts/ld-version.sh
index b9513d224476..d9003550bd72 100755
--- a/scripts/ld-version.sh
+++ b/scripts/ld-version.sh
@@ -41,6 +41,11 @@ if [ "$1" = GNU -a "$2" = ld ]; then
 elif [ "$1" = GNU -a "$2" = gold ]; then
 	echo "gold linker is not supported as it is not capable of linking the kernel proper." >&2
 	exit 1
+elif [ "$1" = mold ]; then
+        version=$2
+        min_version=1.1
+        name=MOLD
+        disp_name=mold
 else
 	while [ $# -gt 1 -a "$1" != "LLD" ]; do
 		shift
-- 
2.55.0


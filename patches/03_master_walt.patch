--- a/init/Kconfig
+++ b/init/Kconfig
@@ -0,0 +1,6 @@
+config SCHED_WALT
+	bool "Window-Assisted Load Tracking (WALT)"
+	depends on SMP
+	default y
+	help
+	  WALT is an alternative load tracking mechanism for the scheduler.
--- a/include/linux/sched.h
+++ b/include/linux/sched.h
@@ -62,6 +62,7 @@
 struct audit_context;
 struct backing_dev_info;
 struct bio_list;
+struct walt_task_struct;
 struct blk_plug;
 struct bpf_local_storage;
 struct bpf_run_ctx;
@@ -818,6 +819,9 @@
 	unsigned int			flags;
 
 	struct sched_entity		se;
+#ifdef CONFIG_SCHED_WALT
+	struct walt_task_struct		wts;
+#endif
 	struct sched_rt_entity		rt;
 	struct sched_dl_entity		dl;
@@ -2350,4 +2354,16 @@
 
 extern void sched_set_stop_task(int cpu, struct task_struct *stop);
 
+#ifdef CONFIG_SCHED_WALT
+#include <linux/sched/walt.h>
+#define wts_to_ts(mgr) container_of(mgr, struct task_struct, wts)
+static inline bool sched_get_wake_up_idle(struct task_struct *p) { return p->wts.wake_up_idle; }
+static inline int sched_set_wake_up_idle(struct task_struct *p, bool wake_up_idle) { p->wts.wake_up_idle = wake_up_idle; return 0; }
+static inline void set_wake_up_idle(bool wui) { current->wts.wake_up_idle = wui; }
+#else
+static inline bool sched_get_wake_up_idle(struct task_struct *p) { return false; }
+static inline int sched_set_wake_up_idle(struct task_struct *p, bool wui) { return 0; }
+static inline void set_wake_up_idle(bool wui) { }
+#endif
+
 #endif /* _LINUX_SCHED_H */

+#endif
 	}
 #ifdef CONFIG_SCHED_BORE
 	update_burst_score(se);
@@ -13416,3 +13659,11 @@ static void task_fork_fair(struct task_struct *p)
 	se->vruntime -= cfs_rq->min_vruntime;
 	rq_unlock(rq, &rf);
 }

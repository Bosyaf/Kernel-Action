+#ifdef CONFIG_SCHED_BORE
+/*
+ * BORE v5: Enhanced inheritance
+ */
+#define BORE_BC_TIMESTAMP_SHIFT 16
+#define BURST_CACHE_STOP_COUNT 63
+
+static inline bool task_is_bore_eligible(struct task_struct *p)
+{
+	return p && p->sched_class == &fair_sched_class && !p->exit_state;
+}
+
+#ifndef for_each_child_task
+#define for_each_child_task(p, t) \
+	list_for_each_entry(t, &(p)->children, sibling)
+#endif
+
+static inline u32 count_children_upto2(struct task_struct *p)
+{
+	struct list_head *head = &p->children;
+	struct list_head *next = head->next;
+	return (next != head) + (next->next != head);
+}
+
+static inline bool burst_cache_expired(u64 timestamp, u64 now)
+{
+	return (timestamp << BORE_BC_TIMESTAMP_SHIFT) +
+		sched_burst_cache_lifetime < now;
+}
+
+static u32 inherit_from_thread_group(struct task_struct *p, u64 now)
+{
+	struct task_struct *leader = p->group_leader;
+	u64 ts = leader->group_burst_last_cached;
+	u16 pen = leader->group_burst_cache;
+
+	if (burst_cache_expired(ts, now)) {
+		struct task_struct *sibling;
+		u32 count = 0, total = 0;
+
+		for_each_thread(leader, sibling) {
+			if (count >= BURST_CACHE_STOP_COUNT)
+				break;
+			if (!task_is_bore_eligible(sibling))
+				continue;
+			count++;
+			total += sibling->se.burst_penalty;
+		}
+		if (count) {
+			pen = max((u32)(total / count), (u32)p->se.burst_penalty);
+			leader->group_burst_cache = pen;
+			leader->group_burst_last_cached = now;
+		}
+	}
+	return pen;
+}
+
+static u32 inherit_from_ancestor_hub(struct task_struct *parent,
+				      u64 clone_flags, u64 now)
+{
+	struct task_struct *ancestor = parent;
+
+	if (clone_flags & CLONE_PARENT)
+		ancestor = ancestor->real_parent;
+
+	for (struct task_struct *next;
+	     (next = ancestor->real_parent) != ancestor &&
+	     count_children_upto2(ancestor) <= 1;
+	     ancestor = next)
+		;
+
+	u64 ts = ancestor->child_burst_last_cached;
+	u16 pen = ancestor->child_burst_cache;
+
+	if (burst_cache_expired(ts, now)) {
+		struct task_struct *direct_child;
+		u32 count = 0, total = 0;
+
+		for_each_child_task(ancestor, direct_child) {
+			if (count >= BURST_CACHE_STOP_COUNT)
+				break;
+
+			struct task_struct *descendant = direct_child;
+			while (count_children_upto2(descendant) == 1)
+				descendant = list_first_entry(
+					&descendant->children,
+					struct task_struct, sibling);
+
+			if (!task_is_bore_eligible(descendant))
+				continue;
+			count++;
+			total += descendant->se.burst_penalty;
+		}
+		if (count) {
+			pen = max((u32)(total / count), (u32)parent->se.burst_penalty);
+			ancestor->child_burst_cache = pen;
+			ancestor->child_burst_last_cached = now;
+		}
+	}
+	return pen;
+}
+
+static u32 inherit_from_parent(struct task_struct *parent,
+				u64 clone_flags, u64 now)
+{
+	if (clone_flags & CLONE_PARENT)
+		parent = parent->real_parent;
+	return parent->se.burst_penalty;
+}
+
+static u32 inherit_none(struct task_struct *parent, u64 clone_flags, u64 now)
+{
+	return 0;
+}
+
+static void update_inherit_type(void)
+{
+	switch (sched_burst_inherit_type) {
+	case 1:
+		inherit_penalty_fn = inherit_from_parent;
+		break;
+	case 2:
+		inherit_penalty_fn = inherit_from_ancestor_hub;
+		break;
+	default:
+		inherit_penalty_fn = inherit_none;
+	}
+}
+
+void fork_burst_penalty(struct task_struct *p)
+{
+	struct sched_entity *se = &p->se;
+	u64 now = ktime_get_ns();
+	u16 burst_cache;
+
+	if (unlikely(!(sched_bore & 1)))
+		return;
+
+	read_lock(&tasklist_lock);
+
+	if (p->pid == p->tgid) {
+		burst_cache = inherit_penalty_fn(p->real_parent, 0, now);
+	} else {
+		burst_cache = inherit_from_thread_group(p, now);
+	}
+
+	read_unlock(&tasklist_lock);
+
+	se->prev_burst_penalty = max(se->prev_burst_penalty, (u8)burst_cache);
+	se->burst_penalty = se->prev_burst_penalty;
+	update_burst_score(se);
+}
+
+int sched_bore_update_handler(struct ctl_table *table,
+	int write, void __user *buffer, size_t *lenp, loff_t *ppos)
+{
+	int ret = proc_dou8vec_minmax(table, write, buffer, lenp, ppos);
+	if (ret || !write)
+		return ret;
+	reset_task_weights_bore();
+	return 0;
+}
+
+int sched_burst_inherit_type_update_handler(struct ctl_table *table,
+	int write, void __user *buffer, size_t *lenp, loff_t *ppos)
+{
+	int ret = proc_dou8vec_minmax(table, write, buffer, lenp, ppos);
+	if (ret || !write)
+		return ret;
+	update_inherit_type();
+	return 0;
+}
+#endif /* CONFIG_SCHED_BORE */

--- a/fs/f2fs/gc.c
+++ b/fs/f2fs/gc.c
@@ -10,6 +10,12 @@
 #include <linux/delay.h>
 #include <linux/freezer.h>
 #include <linux/sched/signal.h>
+#include <linux/random.h>
+
+/* Rapid GC: Increase cleaning speed for segments */
+#define RAPID_GC_SLEEP_TIME	500	/* 500ms */
+#define RAPID_GC_URGENT_LIMIT	20	/* Max segments per round */
+
 
 #include "f2fs.h"
 #include "node.h"
@@ -148,11 +154,19 @@
 
 	if (gc_type == BG_GC && has_not_enough_free_secs(sbi, 0, 0)) {
 		/*
-		 * For background GC, we should attempt to maximize efficiency
-		 * by selecting dirty segments with a lower reclaim cost.
+		 * Rapid GC: Background cleaning is boosted when storage is getting full
 		 */
-		if (!force && sbi->gc_mode != GC_URGENT_HIGH)
+		if (!force && sbi->gc_mode != GC_URGENT_HIGH) {
+			sbi->gc_thread->gc_wake = 1;
 			return -ENODATA;
+		}
+	}
+
+	/* Boost GC if urgent mode is active */
+	if (sbi->gc_mode == GC_URGENT_HIGH) {
+		wait_ms = RAPID_GC_SLEEP_TIME;
+		if (seg_freed > RAPID_GC_URGENT_LIMIT)
+			goto stop;
 	}
 
 	selp.type = SEARCH_DIRTY;
--- a/fs/f2fs/sysfs.c
+++ b/fs/f2fs/sysfs.c
@@ -588,6 +100,14 @@
 	if (!strcmp(struct_name, "gc_thread")) {
 		if (!strcmp(ptr->name, "gc_idle"))
 			return sprintf(buf, "%u\n", sbi->gc_thread->gc_idle);
+		
+		/* Rapid GC status node */
+		if (!strcmp(ptr->name, "rapid_gc_active"))
+			return sprintf(buf, "1\n");
+
 		return sprintf(buf, "%u\n", sbi->gc_thread->gc_wake);
 	}
+#ifdef CONFIG_SCHED_BORE
+/*
+ * ============================================================
+ * BORE v5: Enhanced inheritance & helper functions
+ * ============================================================
+ */
+
+#define BORE_BC_TIMESTAMP_SHIFT 16
+#define BURST_CACHE_STOP_COUNT 63
+
+static inline bool task_is_bore_eligible(struct task_struct *p)
+{
+	return p && p->sched_class == &fair_sched_class && !p->exit_state;
+}
+
+#ifndef for_each_child_task
+#define for_each_child_task(p, t) \
+	list_for_each_entry(t, &(p)->children, sibling)
+#endif
+
+static inline u32 count_children_upto2(struct task_struct *p)
+{
+	struct list_head *head = &p->children;
+	struct list_head *next = head->next;
+	return (next != head) + (next->next != head);
+}
+
+static inline bool burst_cache_expired(u64 timestamp, u64 now)
+{
+	return (timestamp << BORE_BC_TIMESTAMP_SHIFT) +
+		sched_burst_cache_lifetime < now;
+}
+
+static void update_burst_cache(u64 *timestamp, u16 *penalty,
+	struct task_struct *p, u32 count, u32 total, u64 now)
+{
+	u32 average = count ? total / count : 0;
+	*penalty = max(average, (u32)p->se.burst_penalty);
+	*timestamp = now >> BORE_BC_TIMESTAMP_SHIFT;
+}
+
+/*
+ * Thread group burst inheritance (NEW).
+ * When CLONE_THREAD is used, inherit burst penalty from
+ * the thread group leader's cached average.
+ */
+static u32 inherit_from_thread_group(struct task_struct *p, u64 now)
+{
+	struct task_struct *leader = p->group_leader;
+	u64 *ts = &leader->group_bc.timestamp;
+	u16 *pen = (u16 *)&leader->group_bc.penalty;
+
+	if (burst_cache_expired(*ts, now)) {
+		struct task_struct *sibling;
+		u32 count = 0, total = 0;
+
+		for_each_thread(leader, sibling) {
+			if (count >= BURST_CACHE_STOP_COUNT)
+				break;
+			if (!task_is_bore_eligible(sibling))
+				continue;
+			count++;
+			total += sibling->se.burst_penalty;
+		}
+		update_burst_cache(ts, pen, leader, count, total, now);
+	}
+	return *pen;
+}
+
+/*
+ * Hub/Stub ancestor inheritance (from firelzrd BORE v5).
+ * Walks up the process tree, skipping single-child nodes,
+ * to find the true ancestor hub. Then computes the average
+ * burst penalty of all descendant leaf tasks.
+ *
+ * This prevents "make -j" style fork bombs from overwhelming
+ * interactive tasks by correctly attributing inheritance.
+ */
+static u32 inherit_from_ancestor_hub(struct task_struct *parent,
+				      u64 clone_flags, u64 now)
+{
+	struct task_struct *ancestor = parent;
+
+	if (clone_flags & CLONE_PARENT)
+		ancestor = ancestor->real_parent;
+
+	for (struct task_struct *next;
+	     (next = ancestor->real_parent) != ancestor &&
+	     count_children_upto2(ancestor) <= 1;
+	     ancestor = next)
+		;
+
+	u64 *ts = &ancestor->subtree_bc.timestamp;
+	u16 *pen = (u16 *)&ancestor->subtree_bc.penalty;
+
+	if (burst_cache_expired(*ts, now)) {
+		struct task_struct *direct_child;
+		u32 count = 0, total = 0;
+
+		for_each_child_task(ancestor, direct_child) {
+			if (count >= BURST_CACHE_STOP_COUNT)
+				break;
+
+			struct task_struct *descendant = direct_child;
+			while (count_children_upto2(descendant) == 1)
+				descendant = list_first_entry(
+					&descendant->children,
+					struct task_struct, sibling);
+
+			if (!task_is_bore_eligible(descendant))
+				continue;
+			count++;
+			total += descendant->se.burst_penalty;
+		}
+		update_burst_cache(ts, pen, ancestor, count, total, now);
+	}
+	return *pen;
+}
+
+/*
+ * Simple parent-to-child inheritance.
+ */
+static u32 inherit_from_parent(struct task_struct *parent,
+				u64 clone_flags, u64 now)
+{
+	if (clone_flags & CLONE_PARENT)
+		parent = parent->real_parent;
+
+	u64 *ts = &parent->subtree_bc.timestamp;
+	u16 *pen = (u16 *)&parent->subtree_bc.penalty;
+
+	if (burst_cache_expired(*ts, now)) {
+		struct task_struct *child;
+		u32 count = 0, total = 0;
+
+		for_each_child_task(parent, child) {
+			if (count >= BURST_CACHE_STOP_COUNT)
+				break;
+			if (!task_is_bore_eligible(child))
+				continue;
+			count++;
+			total += child->se.burst_penalty;
+		}
+		update_burst_cache(ts, pen, parent, count, total, now);
+	}
+	return *pen;
+}
+
+static u32 inherit_none(struct task_struct *parent, u64 clone_flags, u64 now)
+{
+	return 0;
+}
+
+static void update_inherit_type(void)
+{
+	switch (sched_burst_inherit_type) {
+	case 1:
+		inherit_penalty_fn = inherit_from_parent;
+		break;
+	case 2:
+		inherit_penalty_fn = inherit_from_ancestor_hub;
+		break;
+	default:
+		inherit_penalty_fn = inherit_none;
+	}
+}
+
+/*
+ * Enhanced fork_burst_penalty - now with thread group support.
+ * Replaces the old version in core.c.
+ */
+void fork_burst_penalty(struct task_struct *p)
+{
+	struct sched_entity *se = &p->se;
+	u64 now = ktime_get_ns();
+	u16 burst_cache;
+
+	if (unlikely(!(sched_bore & 1)))
+		return;
+
+	read_lock(&tasklist_lock);
+
+	if (p->pid == p->tgid) {
+		/* Process fork: use inheritance type */
+		burst_cache = inherit_penalty_fn(
+			p->real_parent, 0 /* clone_flags */, now);
+	} else {
+		/* Thread clone: use thread group inheritance */
+		burst_cache = inherit_from_thread_group(p, now);
+	}
+
+	read_unlock(&tasklist_lock);
+
+	se->prev_burst_penalty = max(se->prev_burst_penalty, (u8)burst_cache);
+	se->burst_penalty = se->prev_burst_penalty;
+	update_burst_score(se);
+}
+
+static void readjust_all_task_weights_bore(void)
+{
+	struct task_struct *task;
+	struct rq *rq;
+	struct rq_flags rf;
+
+	read_lock(&tasklist_lock);
+	for_each_process(task) {
+		if (task->sched_class != &fair_sched_class)
+			continue;
+		rq = task_rq_lock(task, &rf);
+		update_rq_clock(rq);
+		reweight_task(task, effective_prio(task));
+		task_rq_unlock(rq, task, &rf);
+	}
+	read_unlock(&tasklist_lock);
+}
+
+/*
+ * Handler for sched_bore writes.
+ */
+int sched_bore_update_handler(struct ctl_table *table,
+	int write, void __user *buffer, size_t *lenp, loff_t *ppos)
+{
+	int ret = proc_dou8vec_minmax(table, write, buffer, lenp, ppos);
+	if (ret || !write)
+		return ret;
+
+	readjust_all_task_weights_bore();
+	return 0;
+}
+
+/*
+ * Handler for sched_burst_inherit_type writes.
+ */
+int sched_burst_inherit_type_update_handler(struct ctl_table *table,
+	int write, void __user *buffer, size_t *lenp, loff_t *ppos)
+{
+	int ret = proc_dou8vec_minmax(table, write, buffer, lenp, ppos);
+	if (ret || !write)
+		return ret;
+
+	update_inherit_type();
+	return 0;
+}
+
+static void __init sched_init_bore_values(void)
+{
+	update_inherit_type();
+	init_task.se.burst_time = 0;
+	init_task.se.prev_burst_penalty = 0;
+	init_task.se.curr_burst_penalty = 0;
+	init_task.se.burst_penalty = 0;
+	init_task.child_burst_cache = 0;
+	init_task.child_burst_count_cache = 0;
+	init_task.child_burst_last_cached = 0;
+	init_task.group_burst_cache = 0;
+	init_task.group_burst_last_cached = 0;
+}
+
+static void sched_fork_bore_reset(struct task_struct *p)
+{
+	p->se.burst_time = 0;
+	p->se.curr_burst_penalty = 0;
+	p->se.stop_update = false;
+	p->se.futex_waiting = false;
+	p->child_burst_cache = 0;
+	p->child_burst_count_cache = 0;
+	p->child_burst_last_cached = 0;
+	p->group_burst_cache = 0;
+	p->group_burst_last_cached = 0;
+}
+
+#else /* !CONFIG_SCHED_BORE */
+static void sched_init_bore_values(void) {}
+static void sched_fork_bore_reset(struct task_struct *p) {}
+#endif /* CONFIG_SCHED_BORE */
+
+void reset_task_bore(struct task_struct *p)
+{
+	sched_fork_bore_reset(p);
+}

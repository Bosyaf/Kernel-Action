+/*
+ * Unified binary smooth using sched_burst_smoothness (0-3).
+ * Falls back to legacy long/short if smoothness == 0 for compatibility.
+ */
+static inline u32 binary_smooth(u32 new, u32 old)
+{
+	int increment = new - old;
+
+	if (sched_burst_smoothness) {
+		/* New unified mode */
+		if (increment >= 0)
+			return old + (increment >> sched_burst_smoothness);
+		else
+			return old - (-increment >> sched_burst_smoothness);
+	}
+	/* Legacy mode */
+	return increment >= 0 ?
+		old + (increment >> (int)sched_burst_smoothness_long) :
+		old - (-increment >> (int)sched_burst_smoothness_short);
 }
 
 static void restart_burst(struct sched_entity *se) {
 	se->burst_penalty = se->prev_burst_penalty =
 		binary_smooth(se->curr_burst_penalty, se->prev_burst_penalty);
+	se->curr_burst_penalty = 0;
+	se->burst_time = 0;
+	update_burst_score(se);
+}
+
+static inline bool bore_burst_preempt_enabled(void) {
+	return sched_bore & 2;
 }
 #endif /* CONFIG_SCHED_BORE */
 
